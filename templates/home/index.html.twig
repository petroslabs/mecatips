{% extends 'base.html.twig' %}

{% block title %}MécaTips — les tips de terrain de la mécanique{% endblock %}
{% block meta_description %}Ce que ton oncle ou le mécano du coin te glisse à l'oreille pendant qu'il bosse — recensé, vérifié par un comité, gratuit à consulter.{% endblock %}

{% block body %}
    <section class="hero">
        <span class="eyebrow">Conseils de terrain, vérifiés par des mécaniciens</span>
        <h1 class="hero__title">Les tips qu'on <span class="marker">ne trouve pas dans les tutos</span>.</h1>
        <p class="hero__lead">Ce que ton oncle ou le mécano du coin te glisse à l'oreille pendant qu'il bosse — recensé, vérifié par un comité, gratuit à consulter.</p>

        {% if featuredTip %}
            <div class="hero__example">
                <span class="hero__example-label">Récemment publié</span>
                <ul class="tip-list">
                    <li class="tip-list__item">
                        <a href="{{ path('tip_show', { slug: featuredTip.slug }) }}">{{ featuredTip.publishedTitle }}</a>
                        <div class="tip-list__meta">
                            <span>{{ featuredTip.category.parent.name }} — {{ featuredTip.category.name }}</span>
                            <span>{{ featuredTip.type.value }}</span>
                            {% if featuredTip.vehicle %}
                                <a href="{{ path('vehicle_show', { id: featuredTip.vehicle.id }) }}">{{ featuredTip.vehicle.label }}</a>
                            {% else %}
                                <span>Tous véhicules</span>
                            {% endif %}
                        </div>
                    </li>
                </ul>
            </div>
        {% endif %}

        <div class="hero__actions">
            <a href="{{ path('tip_index') }}" class="btn">Voir tous les tips</a>
            {% if app.user %}
                <a href="{{ path('tip_new') }}" class="btn btn-outline">Proposer un tip</a>
            {% else %}
                <a href="{{ path('registration') }}" class="btn btn-outline">Créer un compte</a>
            {% endif %}
        </div>
    </section>
{% endblock %}
