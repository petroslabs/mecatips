{% extends 'base.html.twig' %}

{% block title %}Recherche — MécaTips{% endblock %}

{% block body %}
    <nav class="breadcrumb">
        <a href="{{ path('tip_index') }}">Véhicules</a>
        <span class="breadcrumb__sep">/</span>
        <span>Recherche libre</span>
    </nav>

    <h1>Recherche libre</h1>
    <p class="browse-intro">Tu préfères parcourir par catégorie et opération ? <a href="{{ path('tip_index') }}">Reviens au parcours par tuiles</a>.</p>

    <form method="get" class="filter-bar">
        <div>
            <label for="filter-q">Recherche</label>
            <input type="text" id="filter-q" name="q" value="{{ filters.q }}" placeholder="mots-clés...">
        </div>

        <div>
            <label for="filter-category">Opération</label>
            <select id="filter-category" name="category">
                <option value="">Toutes</option>
                {% for category in categories %}
                    <option value="{{ category.id }}" {{ filters.category and filters.category.id == category.id ? 'selected' }}>{{ category.parent.name }} — {{ category.name }}</option>
                {% endfor %}
            </select>
        </div>

        <div>
            <label for="filter-vehicle">Véhicule</label>
            <select id="filter-vehicle" name="vehicle">
                <option value="">Tips généraux</option>
                {% for vehicle in vehicles %}
                    <option value="{{ vehicle.id }}" {{ filters.vehicle and filters.vehicle.id == vehicle.id ? 'selected' }}>{{ vehicle.label }}</option>
                {% endfor %}
            </select>
        </div>

        <div>
            <label for="filter-type">Type</label>
            <select id="filter-type" name="type">
                <option value="">Tous</option>
                {% for type in types %}
                    <option value="{{ type.name }}" {{ filters.type and filters.type.name == type.name ? 'selected' }}>{{ type.value }}</option>
                {% endfor %}
            </select>
        </div>

        <div>
            <label for="filter-sort">Tri</label>
            <select id="filter-sort" name="sort">
                <option value="recent" {{ filters.sort == 'recent' ? 'selected' }}>Plus récents</option>
                <option value="useful" {{ filters.sort == 'useful' ? 'selected' }}>Mieux notés</option>
            </select>
        </div>

        <button type="submit">Filtrer</button>
        {% if hasFilters %}
            <a href="{{ path('tip_search') }}" class="filter-bar__reset">Réinitialiser</a>
        {% endif %}
    </form>

    {% if tips is empty %}
        <p>
            {% if hasFilters %}
                Aucun tip ne correspond à ces filtres.
            {% else %}
                Aucun tip publié pour le moment.
            {% endif %}
        </p>
    {% endif %}

    <ul class="tip-list">
        {% for tip in tips %}
            <li class="tip-list__item">
                <a href="{{ path('tip_show', { id: tip.id }) }}">{{ tip.publishedTitle }}</a>
                <div class="tip-list__meta">
                    <span>{{ tip.category.parent.name }} — {{ tip.category.name }}</span>
                    <span>{{ tip.type.value }}</span>
                    {% if tip.vehicle %}
                        <a href="{{ path('vehicle_show', { id: tip.vehicle.id }) }}">{{ tip.vehicle.label }}</a>
                    {% else %}
                        <span>Tous véhicules</span>
                    {% endif %}
                </div>
            </li>
        {% endfor %}
    </ul>
{% endblock %}
