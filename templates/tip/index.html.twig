{% extends 'base.html.twig' %}

{% block title %}Tips — MécaTips{% endblock %}

{% block body %}
    <h1>Les tips publiés</h1>

    {% if tips is empty %}
        <p>Aucun tip publié pour le moment.</p>
    {% endif %}

    <ul class="tip-list">
        {% for tip in tips %}
            <li class="tip-list__item">
                <a href="{{ path('tip_show', { id: tip.id }) }}">{{ tip.publishedTitle }}</a>
                <div class="tip-list__meta">
                    <span>{{ tip.category.name }}</span>
                    <span>{{ tip.type.value }}</span>
                    <span>{{ tip.vehicle ? tip.vehicle.label : 'Tous véhicules' }}</span>
                </div>
            </li>
        {% endfor %}
    </ul>
{% endblock %}
