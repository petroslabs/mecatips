{# Gabarit des pages d'erreur (404, 403, 500...). N'étend volontairement pas
   base.html.twig : si un 500 vient d'une base de données injoignable, le
   header applicatif (compteur de notifications, menus liés à app.user) qui
   interroge la base planterait à son tour, et Symfony retomberait sur sa
   page d'erreur brute non stylée faute de pouvoir rendre celle-ci. Ce
   gabarit ne dépend que du routeur et de l'asset mapper, jamais de la base. #}
<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Erreur — MécaTips{% endblock %}</title>
        <meta name="robots" content="noindex">
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.1em%22 font-size=%22110%22>🔧</text></svg>">

        <script>
            (function () {
                var stored = localStorage.getItem('mecatips-theme');
                var theme = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
                document.documentElement.setAttribute('data-theme', theme);
            })();
        </script>

        {{ importmap('app') }}
    </head>
    <body>
        <header class="site-header">
            <a href="{{ path('app_home') }}" class="brand">MécaTips</a>
        </header>

        <main class="site-main">
            <div class="error-page">
                {% block icon %}
                    <svg class="error-page__icon" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M12 3.5 L21.5 20 H2.5 Z" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
                        <line x1="12" y1="10" x2="12" y2="14.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                        <circle cx="12" cy="17.3" r="1.1" fill="currentColor" stroke="none"/>
                    </svg>
                {% endblock %}
                <p class="error-page__code">{% block code %}{% endblock %}</p>
                <h1>{% block heading %}{% endblock %}</h1>
                <p>{% block message %}{% endblock %}</p>
                <a href="{{ path('app_home') }}" class="btn">Retour à l'accueil</a>
            </div>
        </main>

        <footer class="site-footer">
            <nav class="site-footer__links">
                <a href="{{ path('legal_notice') }}">Mentions légales</a>
                <a href="{{ path('legal_terms') }}">CGU</a>
                <a href="{{ path('legal_privacy') }}">Confidentialité</a>
            </nav>
        </footer>
    </body>
</html>
