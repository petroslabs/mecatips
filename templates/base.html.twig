<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}MécaTips{% endblock %}</title>
        <meta name="description" content="{% block meta_description %}Tips de mécanique auto vérifiés par un comité de contributeurs — ce que le mécano du coin te glisse à l'oreille, pas ce qu'on trouve dans les tutos génériques.{% endblock %}">
        <link rel="canonical" href="{% block canonical %}{{ url(app.request.attributes.get('_route'), app.request.attributes.get('_route_params')) }}{% endblock %}">
        <meta name="robots" content="{% block robots %}index, follow{% endblock %}">

        <meta property="og:site_name" content="MécaTips">
        <meta property="og:type" content="{% block og_type %}website{% endblock %}">
        <meta property="og:title" content="{% block og_title %}{{ block('title') }}{% endblock %}">
        <meta property="og:description" content="{% block og_description %}{{ block('meta_description') }}{% endblock %}">
        <meta property="og:url" content="{% block og_url %}{{ block('canonical') }}{% endblock %}">

        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.1em%22 font-size=%22110%22>🔧</text></svg>">

        {# Détection du thème avant le premier rendu, pour éviter un flash du
           mauvais thème — doit s'exécuter avant que le CSS (qui lit
           :root[data-theme]) ne soit appliqué. Le contrôleur Stimulus
           "theme" ne gère que le clic sur le bouton une fois la page chargée. #}
        <script>
            (function () {
                var stored = localStorage.getItem('mecatips-theme');
                var theme = stored || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
                document.documentElement.setAttribute('data-theme', theme);
            })();
        </script>

        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body>
        {# Filtre de distorsion utilisé par .stamp (badge tampon encreur) — un
           seul filtre partagé, référencé via filter: url(#stampDistress). #}
        <svg width="0" height="0" style="position: absolute" aria-hidden="true">
            <defs>
                <filter id="stampDistress" x="-20%" y="-20%" width="140%" height="140%">
                    <feTurbulence type="fractalNoise" baseFrequency="0.9" numOctaves="2" result="noise" seed="7"></feTurbulence>
                    <feDisplacementMap in="SourceGraphic" in2="noise" scale="3.5"></feDisplacementMap>
                </filter>
            </defs>
        </svg>

        {# Sprite d'icônes de la nav — tracé simple façon schéma d'atelier
           (traits, pas de remplissage), une seule définition réutilisée via
           <use>, même logique que le filtre .stamp ci-dessus. #}
        <svg width="0" height="0" style="position: absolute" aria-hidden="true">
            <defs>
                <symbol id="icon-wrench" viewBox="0 0 24 24">
                    <polygon points="12,4 17.9,7.5 17.9,14.5 12,18 6.1,14.5 6.1,7.5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
                    <circle cx="12" cy="11" r="3" fill="none" stroke="currentColor" stroke-width="1.6"/>
                </symbol>
                <symbol id="icon-trophy" viewBox="0 0 24 24">
                    <rect x="4" y="14" width="4" height="6" fill="none" stroke="currentColor" stroke-width="1.6"/>
                    <rect x="10" y="9" width="4" height="11" fill="none" stroke="currentColor" stroke-width="1.6"/>
                    <rect x="16" y="12" width="4" height="8" fill="none" stroke="currentColor" stroke-width="1.6"/>
                </symbol>
                <symbol id="icon-shield" viewBox="0 0 24 24">
                    <path d="M12 3 L19 6 V11.5 C19 16 16 19.5 12 21 C8 19.5 5 16 5 11.5 V6 Z" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
                    <polyline points="8.5,12 11,14.5 15.5,9.5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                </symbol>
                <symbol id="icon-bell" viewBox="0 0 24 24">
                    <path d="M7 9 C7 5.5 9.2 3 12 3 C14.8 3 17 5.5 17 9 V13 L19 16 H5 L7 13 Z" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
                    <path d="M9.5 18.5 a2.5 2.5 0 0 0 5 0" fill="none" stroke="currentColor" stroke-width="1.6"/>
                </symbol>
                <symbol id="icon-plus" viewBox="0 0 24 24">
                    <line x1="12" y1="5" x2="12" y2="19" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                    <line x1="5" y1="12" x2="19" y2="12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                </symbol>
                <symbol id="icon-user" viewBox="0 0 24 24">
                    <circle cx="12" cy="8" r="4" fill="none" stroke="currentColor" stroke-width="1.6"/>
                    <path d="M4 21 C4 16.5 7.6 14 12 14 C16.4 14 20 16.5 20 21" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                </symbol>
                <symbol id="icon-user-plus" viewBox="0 0 24 24">
                    <circle cx="10" cy="8" r="3.5" fill="none" stroke="currentColor" stroke-width="1.6"/>
                    <path d="M3 21 C3 16.8 6.2 14.5 10 14.5 C11 14.5 11.9 14.65 12.7 14.95" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                    <line x1="18" y1="9" x2="18" y2="15" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                    <line x1="15" y1="12" x2="21" y2="12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                </symbol>
                <symbol id="icon-login" viewBox="0 0 24 24">
                    <path d="M15 4 H19 V20 H15" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                    <line x1="11" y1="12" x2="3" y2="12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                    <polyline points="7,8 3,12 7,16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                </symbol>
                <symbol id="icon-logout" viewBox="0 0 24 24">
                    <path d="M9 4 H5 V20 H9" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                    <line x1="13" y1="12" x2="21" y2="12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                    <polyline points="17,8 21,12 17,16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                </symbol>
                <symbol id="icon-star" viewBox="0 0 24 24">
                    <polygon points="12,2 14.7,8.6 21.8,9.1 16.3,13.6 18.2,20.6 12,16.8 5.8,20.6 7.7,13.6 2.2,9.1 9.3,8.6" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
                </symbol>
                <symbol id="icon-flag" viewBox="0 0 24 24">
                    <line x1="5" y1="3" x2="5" y2="21" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
                    <path d="M5 4 H18 L15 8 L18 12 H5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
                </symbol>
                <symbol id="icon-car" viewBox="0 0 24 24">
                    <path d="M4 15 L5.5 10 H16.5 L19 15" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
                    <rect x="3" y="15" width="18" height="3.5" rx="1" fill="none" stroke="currentColor" stroke-width="1.6"/>
                    <circle cx="7.5" cy="18.5" r="1.6" fill="none" stroke="currentColor" stroke-width="1.6"/>
                    <circle cx="16.5" cy="18.5" r="1.6" fill="none" stroke="currentColor" stroke-width="1.6"/>
                </symbol>
                <symbol id="icon-sun" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="4" fill="none" stroke="currentColor" stroke-width="1.6"/>
                    <g stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
                        <line x1="12" y1="2.5" x2="12" y2="5"/>
                        <line x1="12" y1="19" x2="12" y2="21.5"/>
                        <line x1="2.5" y1="12" x2="5" y2="12"/>
                        <line x1="19" y1="12" x2="21.5" y2="12"/>
                        <line x1="5" y1="5" x2="6.8" y2="6.8"/>
                        <line x1="17.2" y1="17.2" x2="19" y2="19"/>
                        <line x1="19" y1="5" x2="17.2" y2="6.8"/>
                        <line x1="6.8" y1="17.2" x2="5" y2="19"/>
                    </g>
                </symbol>
                <symbol id="icon-moon" viewBox="0 0 24 24">
                    <path d="M20 14.5 A8.5 8.5 0 1 1 9.5 4 A7 7 0 0 0 20 14.5 Z" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
                </symbol>
            </defs>
        </svg>

        <header class="site-header">
            <a href="{{ path('app_home') }}" class="brand">MécaTips</a>
            <nav class="site-nav">
                <a href="{{ path('tip_index') }}"><svg class="nav-icon"><use href="#icon-wrench"/></svg>Tips</a>
                <a href="{{ path('ranking_index') }}"><svg class="nav-icon"><use href="#icon-trophy"/></svg>Classement</a>
                {% if app.user %}
                    {% if is_granted('ROLE_COMMITTEE') %}
                        <details class="nav-dropdown">
                            <summary><svg class="nav-icon"><use href="#icon-shield"/></svg>Comité</summary>
                            <div class="nav-dropdown__menu">
                                <a href="{{ path('committee_queue') }}"><svg class="nav-icon"><use href="#icon-shield"/></svg>Validation</a>
                                <a href="{{ path('committee_reports') }}"><svg class="nav-icon"><use href="#icon-flag"/></svg>Signalements</a>
                                <a href="{{ path('committee_vehicles') }}"><svg class="nav-icon"><use href="#icon-car"/></svg>Véhicules</a>
                                {% if is_granted('ROLE_ADMIN') %}
                                    <a href="{{ path('admin_committee_index') }}"><svg class="nav-icon"><use href="#icon-user"/></svg>Gestion du comité</a>
                                {% endif %}
                            </div>
                        </details>
                    {% endif %}
                    {% set unreadCount = unread_notification_count() %}
                    <a href="{{ path('notification_index') }}" class="nav-icon-only" aria-label="Notifications{% if unreadCount > 0 %} ({{ unreadCount }} non lue{{ unreadCount > 1 ? 's' : '' }}){% endif %}">
                        <svg class="nav-icon"><use href="#icon-bell"/></svg>{% if unreadCount > 0 %}<span class="notification-badge">{{ unreadCount }}</span>{% endif %}
                    </a>
                    <a href="{{ path('tip_new') }}" class="site-nav__cta"><svg class="nav-icon"><use href="#icon-plus"/></svg>Proposer un tip</a>
                    <details class="nav-dropdown">
                        <summary><svg class="nav-icon"><use href="#icon-user"/></svg>{{ app.user.username }}</summary>
                        <div class="nav-dropdown__menu">
                            <a href="{{ path('contributor_show', { username: app.user.username }) }}"><svg class="nav-icon"><use href="#icon-user"/></svg>Mon profil</a>
                            <a href="{{ path('tip_mine') }}"><svg class="nav-icon"><use href="#icon-wrench"/></svg>Mes tips</a>
                            <a href="{{ path('favorite_index') }}"><svg class="nav-icon"><use href="#icon-star"/></svg>Favoris</a>
                            <a href="{{ path('security_logout') }}"><svg class="nav-icon"><use href="#icon-logout"/></svg>Déconnexion</a>
                        </div>
                    </details>
                {% else %}
                    <a href="{{ path('security_login') }}"><svg class="nav-icon"><use href="#icon-login"/></svg>Connexion</a>
                    <a href="{{ path('registration') }}" class="site-nav__cta"><svg class="nav-icon"><use href="#icon-user-plus"/></svg>S'inscrire</a>
                {% endif %}
                <button type="button" class="theme-toggle nav-icon-only" data-controller="theme" data-action="theme#toggle" aria-label="Changer de thème">
                    <svg class="nav-icon"><use data-theme-target="icon" href="#icon-moon"/></svg>
                </button>
            </nav>
        </header>

        <main class="site-main">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash flash--{{ label }}">{{ message }}</div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </main>
    </body>
</html>
